# Общее
NODE_ENV=development
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=3000

# Postgres
POSTGRES_USER=hockey
POSTGRES_PASSWORD=hockey_dev_password
POSTGRES_DB=hockey
POSTGRES_PORT=5432
# Для локального `pnpm dev:server` (Node-процесс на хосте) → localhost.
# Внутри docker-compose.yml значение переопределяется на `postgres` (service name).
DATABASE_URL=postgres://hockey:hockey_dev_password@localhost:5432/hockey

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Тестовая БД и тестовый Redis (integration-тесты серверных плагинов).
# Локально: создай `hockey_test` рядом с `hockey` и укажи логический Redis DB 15.
TEST_DATABASE_URL=postgres://hockey:hockey_dev_password@localhost:5432/hockey_test
TEST_REDIS_URL=redis://localhost:6379/15

# Caddy
# На проде заменить на hockey.inbotwetrust.ru
APP_DOMAIN=localhost
ADMIN_EMAIL=admin@example.com

# Docker image tag (используется в docker-compose.yml для прод-pull, на локалке игнорируется благодаря override)
IMAGE_TAG=latest

# Секреты (обязательно заменить на проде; min 16 chars для JWT/REFRESH/DAILY_SEED)
JWT_SECRET=dev-jwt-secret-at-least-16-chars
REFRESH_SECRET=dev-refresh-secret-at-least-16-chars
TELEGRAM_BOT_TOKEN=123456:REPLACE_WITH_REAL_BOT_TOKEN
DAILY_SEED_SECRET=dev-daily-seed-secret-at-least-16-chars
# VK ID OAuth (id.vk.com). App ID is public; protected/service keys are not used.
VK_APP_ID=54571497
# Comma-separated Telegram provider IDs allowed for one-off account recovery.
# Empty by default: already-linked Telegram/VK identities stay blocked for everyone.
ACCOUNT_RECOVERY_TELEGRAM_PROVIDER_UIDS=

# Web Push (PWA notifications). Generate a VAPID key pair before enabling in production.
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@example.com

# Object storage (S3-compatible) for user media: chat attachments and custom avatars.
# Do not commit real keys. For Cloud.ru use endpoint without bucket path:
# OBJECT_STORAGE_ENDPOINT=https://s3.cloud.ru
# OBJECT_STORAGE_REGION=ru-central-1
# OBJECT_STORAGE_BUCKET=hockey-bucket-...
# OBJECT_STORAGE_PUBLIC_BASE_URL=https://s3.cloud.ru/hockey-bucket-...
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_MAX_UPLOAD_BYTES=26214400

# Web (Vite) — bot username without @, used by Telegram Login Widget
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
# VK ID OAuth app id (id.vk.com), baked into the web bundle.
VITE_VK_APP_ID=54571497

# UUID of the system user account used as created_by for system chat channels.
# Set this to the id of any existing user row (e.g. an admin Telegram account
# that already logged in once). Required only when running `pnpm chat:seed`.
SYSTEM_USER_ID=
