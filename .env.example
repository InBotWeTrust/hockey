# Общее
NODE_ENV=development
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=3000

# Postgres (для будущих планов, не используется в Плане 1)
POSTGRES_USER=hockey
POSTGRES_PASSWORD=hockey_dev_password
POSTGRES_DB=hockey
POSTGRES_PORT=5432
DATABASE_URL=postgres://hockey:hockey_dev_password@postgres:5432/hockey

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Caddy
APP_DOMAIN=localhost
ADMIN_EMAIL=admin@example.com

# Секреты (Plan 2+)
JWT_SECRET=replace-me-in-prod
REFRESH_SECRET=replace-me-in-prod
TELEGRAM_BOT_TOKEN=
VK_APP_ID=
VK_APP_SECRET=
VK_REDIRECT_URI=https://localhost/api/auth/vk/callback
